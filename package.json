{
  "name": "cloudflare-assets",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare R2 资产管理工具集（图片爬取 + AI 博客生成）",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "crawl": "node dist/scripts/homepage-bg/crawl-lolicon.js",
    "update-images-info": "node dist/scripts/homepage-bg/update-images-info.js",
    "delete-images": "node dist/scripts/homepage-bg/delete-images.js",
    "delete-non-lolicon": "node dist/scripts/homepage-bg/delete-non-lolicon.js",
    "list-prefixes": "node dist/scripts/homepage-bg/list-prefixes.js",
    "enrich-metadata": "node dist/scripts/homepage-bg/enrich-metadata.js",
    "crawl-cnblogs": "node dist/scripts/blog/crawl-cnblogs.js",
    "generate-article": "node dist/scripts/blog/generate-article.js",
    "cleanup-blog": "node dist/scripts/blog/cleanup-blog.js",
    "fix-manifest-tags": "node dist/scripts/blog/fix-manifest-tags.js",
    "delete-all-posts": "node dist/scripts/blog/delete-all-posts.js",
    "delete-first-posts": "node dist/scripts/blog/delete-first-posts.js",
    "delete-old-posts": "node dist/scripts/blog/delete-old-posts.js",
    "cdn-list": "node dist/scripts/cdn/list-domains.js",
    "cdn-sync": "node dist/scripts/cdn/sync-domains.js"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "debug": "^4.4.3"
  },
  "engines": {
    "node": ">=20"
  }
}
