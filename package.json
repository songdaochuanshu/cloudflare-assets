{
  "name": "cloudflare-assets",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare R2 资产管理工具集（图片爬取 + AI 博客生成）",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "crawl": "node dist/buckets/homepage-bg/crawl-lolicon.js",
    "update-images-info": "node dist/buckets/homepage-bg/update-images-info.js",
    "delete-images": "node dist/buckets/homepage-bg/delete-images.js",
    "delete-non-lolicon": "node dist/buckets/homepage-bg/delete-non-lolicon.js",
    "list-prefixes": "node dist/buckets/homepage-bg/list-prefixes.js",
    "enrich-metadata": "node dist/buckets/homepage-bg/enrich-metadata.js",
    "crawl-cnblogs": "node dist/buckets/songdaochuanshu-static/crawl-cnblogs.js",
    "generate-article": "node dist/buckets/songdaochuanshu-static/generate-article.js",
    "cleanup-blog": "node dist/buckets/songdaochuanshu-static/cleanup-blog.js",
    "fix-manifest-tags": "node dist/buckets/songdaochuanshu-static/fix-manifest-tags.js",
    "delete-all-posts": "node dist/buckets/songdaochuanshu-static/delete-all-posts.js",
    "delete-first-posts": "node dist/buckets/songdaochuanshu-static/delete-first-posts.js",
    "delete-old-posts": "node dist/buckets/songdaochuanshu-static/delete-old-posts.js"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0"
  },
  "engines": {
    "node": ">=20"
  }
}
